{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://zyqzypyncugihrawhppg.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "aivia-mcp",
      "version": "0.1.0",
      "title": "Aivia"
    },
    "tools": [
      {
        "name": "get_business_info",
        "title": "Get business info",
        "description": "Return the signed-in user's business profile: name, type, address, main phone, website, hours-related settings, and Aivia AI receptionist status.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_bookings",
        "title": "List bookings",
        "description": "List upcoming or recent bookings for the signed-in user's business. Returns booking code, customer name/phone, service, staff, start/end time, status, and payment status.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Max rows to return (default 25)."
            },
            "status": {
              "type": "string",
              "enum": [
                "confirmed",
                "pending",
                "cancelled",
                "completed",
                "no_show"
              ],
              "description": "Filter by booking status."
            },
            "from": {
              "type": "string",
              "description": "ISO date/time lower bound on start_time."
            },
            "to": {
              "type": "string",
              "description": "ISO date/time upper bound on start_time."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_customers",
        "title": "List customers",
        "description": "List customers for the signed-in user's business, most recently updated first. Useful for lookups, exports, and analytics.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Case-insensitive substring match on customer name, phone, or email."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Max rows (default 50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_calls",
        "title": "List recent calls",
        "description": "List recent AI receptionist call log entries for the signed-in user's business, including caller, duration, outcome, and short summary.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Max rows (default 25)."
            },
            "needs_review_only": {
              "type": "boolean",
              "description": "If true, only return calls flagged for review."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_services",
        "title": "List services",
        "description": "List the services (menu of offerings) configured for the signed-in user's business, with price and duration.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
